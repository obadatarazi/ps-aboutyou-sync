# ============================================================
#  PrestaShop ↔ AboutYou Sync — copy to .env and edit values
#  All runtime behavior is driven from this file.
# ============================================================

# ------ Application ------
APP_ENV=production
APP_TIMEZONE=UTC
UI_ENABLED=true
# Optional: web dashboard login at public/index.php (defaults if unset: admin / prestasync2024)
UI_AUTH_USER=
UI_AUTH_PASSWORD=

# ------ PrestaShop ------
PS_BASE_URL=https://your-shop.example.com
PS_API_KEY=your_prestashop_webservice_key
PS_API_OUTPUT=JSON
PS_LANGUAGE_ID=1
PS_SHOP_ID=1

# ------ AboutYou Seller Center ------
AY_BASE_URL=https://partner.aboutyou.com/api/v1
AY_API_KEY=your_aboutyou_api_key
AY_MERCHANT_ID=
AY_BRAND_ID=YOUR_BRAND_ID

# ------ Sync ------
SYNC_BATCH_SIZE=50
SYNC_INCREMENTAL=true
SYNC_LAST_SYNC_FILE=./logs/last_sync.json
SYNC_MAX_EXECUTION_TIME=0
SYNC_LOCK_FILE=./logs/sync-run.lock
TEST_MODE=false
DRY_RUN=false
PS_HTTP_TIMEOUT=20
PS_HTTP_CONNECT_TIMEOUT=8
PS_STOCK_PROGRESS_STEP=50
AY_HTTP_TIMEOUT=20
AY_HTTP_CONNECT_TIMEOUT=8
STOCK_SYNC_MAX_ITEMS=0

# ------ Images for AboutYou (1125×1500, 3:4) ------
# Requires PHP GD. AboutYou must fetch IMAGE_NORMALIZE_PUBLIC_BASE_URL over HTTPS.
IMAGE_NORMALIZE_FOR_AY=false
IMAGE_NORMALIZE_PUBLIC_BASE_URL=https://your-public-host.example.com/ay-normalized
# true: log each skipped/broken image at notice; false: debug only (default, less noise)
IMAGE_NORMALIZE_VERBOSE_SKIPS=false

# ------ Textile material composition (AboutYou IDs) ------
# Enable when cluster_id / material_id are filled from your Seller Center category.
AY_MATERIAL_COMPOSITION_TEXTILE_ENABLED=false
# Fallback JSON if PrestaShop has no composition feature (one line, valid JSON).
AY_DEFAULT_MATERIAL_COMPOSITION_TEXTILE=
# Example: [{"cluster_id":164588,"components":[{"material_id":293177,"fraction":100}]}]
# Map words in PS feature values to AboutYou material_id (JSON object, one line).
AY_MATERIAL_NAME_TO_ID={}
# Example: {"cotton":293177,"polyester":293178}
# PrestaShop Catalog > Features: id of the “composition” feature (comma-separated if several).
PS_MATERIAL_FEATURE_IDS=
# AboutYou cluster for parsed components (e.g. shell / main fabric).
AY_TEXTILE_DEFAULT_CLUSTER_ID=0

# ------ Queue ------
QUEUE_DRIVER=file
QUEUE_PATH=./logs/queue
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ------ Logging ------
LOG_LEVEL=info
LOG_PATH=./logs/sync.log
LOG_MAX_FILES=30

# ------ Notifications ------
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_TO=admin@yourstore.com
NOTIFY_EMAIL_FROM=sync@yourstore.com
NOTIFY_SMTP_HOST=smtp.yourstore.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=

NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
