# ============================================================
#  PrestaShop ↔ AboutYou Sync — Environment Configuration
# ============================================================

# ------ Application ------
APP_ENV=production
APP_TIMEZONE=UTC
UI_ENABLED=true
# Optional: web dashboard login at public/index.php (defaults if unset: admin / prestasync2024)
UI_AUTH_USER=admin
UI_AUTH_PASSWORD=prestasync2024

# ------ PrestaShop ------
PS_BASE_URL=https://scr-wear.com
PS_API_KEY=ObadaTeastAPI0096394785749032271
PS_API_OUTPUT=JSON          # JSON or XML
PS_LANGUAGE_ID=1            # default language ID in PrestaShop
PS_SHOP_ID=1

# ------ AboutYou Seller Center ------
AY_BASE_URL=https://partner.aboutyou.com/api/v1
AY_API_KEY=JqbSqX2B.sZERg0hRelNDqbmDH9JIecR2qdSjVe3LIP3YkD0IVaN0pI90bZ3erYNs
AY_MERCHANT_ID=
AY_BRAND_ID=SCR.

# ------ Images for AboutYou (1125×1500, 3:4) ------
# Requires PHP GD. AboutYou must fetch IMAGE_NORMALIZE_PUBLIC_BASE_URL over HTTPS.
IMAGE_NORMALIZE_FOR_AY=true
IMAGE_NORMALIZE_PUBLIC_BASE_URL=https://scr-wear.com/ay-normalized
IMAGE_NORMALIZE_VERBOSE_SKIPS=false

# ------ Sync Settings ------
SYNC_BATCH_SIZE=50          # products per API batch
SYNC_INCREMENTAL=true       # only sync changed records
SYNC_LAST_SYNC_FILE=./logs/last_sync.json
TEST_MODE=false
DRY_RUN=false

SYNC_MAX_EXECUTION_TIME=0
SYNC_LOCK_TIMEOUT=300
SYNC_LOCK_FILE=./logs/sync-run.lock

PS_HTTP_TIMEOUT=20
PS_HTTP_CONNECT_TIMEOUT=8
PS_STOCK_PROGRESS_STEP=50

AY_HTTP_TIMEOUT=20
AY_HTTP_CONNECT_TIMEOUT=8

STOCK_SYNC_MAX_ITEMS=0

# ------ Textile material composition (AboutYou cluster_id / material_id from Seller Center) ------
AY_MATERIAL_COMPOSITION_TEXTILE_ENABLED=false
AY_DEFAULT_MATERIAL_COMPOSITION_TEXTILE=
AY_MATERIAL_NAME_TO_ID={}
PS_MATERIAL_FEATURE_IDS=
AY_TEXTILE_DEFAULT_CLUSTER_ID=0

# ------ Queue ------
QUEUE_DRIVER=file           # file | redis
QUEUE_PATH=./logs/queue
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ------ Logging ------
LOG_LEVEL=info              # debug | info | warning | error
LOG_PATH=./logs/sync.log
LOG_MAX_FILES=30

# ------ Notifications ------
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_TO=admin@yourstore.com
NOTIFY_EMAIL_FROM=sync@yourstore.com
NOTIFY_SMTP_HOST=smtp.yourstore.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=

NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
